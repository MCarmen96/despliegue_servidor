version: '3'

services:
  # 1. El Receptor (Camarero)
  nginx-proxy:
    image: jwilder/nginx-proxy
    container_name: nginx-proxy
    ports:
      - "80:80"
    volumes:
      - /var/run/docker.sock:/tmp/docker.sock:ro
    networks:
      - red-internet
  
  letsencrypt-companion:
    image: jrcs/letsencrypt-nginx-proxy-companion
    container_name: letsencrypt-companion
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./certs:/etc/nginx/certs
      - ./vhost.d:/etc/nginx/vhost.d
      - ./html:/usr/share/nginx/html
    depends_on:
      - nginx-proxy
    networks:
      - red-internet
  portainer:
    image: portainer/portainer-ce:latest
    container_name: portainer
    restart: always
    environment:
      - VIRTUAL_HOST=192.168.56.2
      - VIRTUAL_PORT=9000
    ports:
      - "9000:9000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer_data:/data # Cambiado a /data que es el estándar de Portainer
    networks:
      - red-internet
      - red-interna # Portainer puede ver ambas para gestionar todo

# Aquí irán Prometheus (3), Grafana (4) y la App (5)
# 3. El Vigilante (Métricas)
  prometheus:
    image: prom/prometheus
    container_name: prometheus
    restart: always
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml
    networks:
      - red-interna

  # 4. El Artista (Gráficas)
  grafana:
    image: grafana/grafana
    container_name: grafana
    ports:
      - "3000:3000"
    restart: always
    environment:
      - VIRTUAL_HOST=grafana.192.168.56.2  # O la IP que estés usando
      - VIRTUAL_PORT=3000
    networks:
      - red-internet
      - red-interna
      # El "Traductor" que saca las métricas del sistema
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    restart: always
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.ignored-mount-points=^/(sys|proc|dev|host|etc)($$|/)'
    networks:
      - red-interna
networks:
  red-internet:
    external: true
  red-interna:
    external: true

volumes:
  portainer_data:
